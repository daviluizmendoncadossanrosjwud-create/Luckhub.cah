-- FUNÇÕES DE SALVAMENTO LOCAL (DURAÇÃO DA KEY)
local function saveKeyTime()
    if writefile then
        writefile(FILE_NAME, tostring(os.time()))
    end
end

local function getKeyRemainingTime()
    if readfile and isfile and isfile(FILE_NAME) then
        local savedTime = tonumber(readfile(FILE_NAME))
        if savedTime then
            local elapsed = os.time() - savedTime
            local remaining = EXPIRATION_TIME - elapsed
            return remaining > 0 and remaining or 0
        end
    end
    return 0
end

