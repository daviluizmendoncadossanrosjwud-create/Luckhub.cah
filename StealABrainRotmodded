    end)

    btnXray.MouseButton1Click:Connect(function()
        xrayEnabled = not xrayEnabled
        btnXray.Text = "x-ray: "..(xrayEnabled and "ON" or "OFF")
        if xrayEnabled then
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("BasePart") and not v:IsDescendantOf(player.Character) then
                    originalTransparencies[v] = v.Transparency v.Transparency = 0.5
                end
            end
        else
            for part, trans in pairs(originalTransparencies) do if part.Parent then part.Transparency = trans end end
            originalTransparencies = {}
        end
    end)

    btnAtivarSpeed.MouseButton1Click:Connect(function()
        local v = tonumber(SpeedInput.Text)
        if v and player.Character:FindFirstChild("Humanoid") then player.Character.Humanoid.WalkSpeed = v end
    end)

    btnAlto.MouseButton1Click:Connect(function()
        altoAtivo = not altoAtivo
        btnAlto.Text = altoAtivo and "corpo alto: ON" or "deixar corpo alto"
        if getHRP() then
            getHRP().Size = altoAtivo and Vector3.new(0.2,0.2,0.2) or Vector3.new(2,2,1)
            player.Character.Humanoid.HipHeight = altoAtivo and 30 or 0
        end
    end)

    btnTpStealNew.MouseButton1Click:Connect(function()
        local old = getHRP().CFrame
        getHRP().CFrame = player.RespawnLocation and player.RespawnLocation.CFrame or CFrame.new(0,50,0)
        task.wait(0.5)
        getHRP().CFrame = old
    end)

    local myClone = nil
    btnAddClone.MouseButton1Click:Connect(function()
        if myClone then myClone:Destroy() end
        player.Character.Archivable = true
        myClone = player.Character:Clone()
        myClone.Parent = workspace
        myClone:MoveTo(getHRP().Position + Vector3.new(5,0,0))
    end)

    btnTpClone.MouseButton1Click:Connect(function() if myClone then getHRP().CFrame = myClone.HumanoidRootPart.CFrame end end)

    local frozen = false
    btnFreeze.MouseButton1Click:Connect(function()
        frozen = not frozen
        btnFreeze.Text = frozen and "time: OFF" or "congelar time"
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v:IsDescendantOf(player.Character) then v.Anchored = frozen end
        end
    end)

    RunService.Stepped:Connect(function()
        if autoProximityEnabled then
            for _,obj in ipairs(game:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then obj.HoldDuration = 0 end
