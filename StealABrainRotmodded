    btnTpBaixo.MouseButton1Click:Connect(function() if getHRP() then getHRP().CFrame = getHRP().CFrame + Vector3.new(0,-15,0) end end)

    btnAutoProx.MouseButton1Click:Connect(function()
        autoProximityEnabled = not autoProximityEnabled
        btnAutoProx.Text = "auto proximity: "..(autoProximityEnabled and "ON" or "OFF")
    end)

    btnInfJump.MouseButton1Click:Connect(function()
        infiniteJumpEnabled = not infiniteJumpEnabled
